# VPN Compare — .gitignore
# bestvpncompareonline.com

# ── Local backups (generated by update-site.js on laptop) ──
backups/
_UPDATES/
# ── OS system files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Windows temp files ──
*.tmp
*.bak
~$*

# ── Editor files ──
.vscode/
*.sublime-workspace
*.suo
*.user

# ── Node (if you ever run npm install locally) ──
node_modules/

# ── Logs ──
*.log
npm-debug.log*
